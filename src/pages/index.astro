  #result .seg-btn {
    background: var(--surface); border: none; color: var(--ink-3);
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; font-weight: 600;
    padding: 5px 11px; cursor: pointer; transition: background 0.12s, color 0.12s;
