---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';

const title = 'SwitchHunt — find any Windows installer’s silent-install switch';
const description =
  'Drop a Windows installer (MSI/EXE) and get its silent-install command. Detects MSI, Inno Setup, ' +
  'NSIS, WiX Burn, InstallShield and SFX. Runs entirely in your browser — nothing is uploaded. Free.';
---

<Layout title={title} description={description}>
  <!-- Minimal header (no marketing nav) — keeps this tool page reading as a free standalone tool,
       not a product landing page. The "Built by RFF" byline at the bottom carries the funnel. -->
  <header class="tool-nav">
    <a href="https://getrff.com" aria-label="RFF home"><Logo /></a>
    <a href="https://getrff.com" class="tool-nav-by">What’s RFF? →</a>
  </header>

  <main class="wrap">
    <p class="kicker">FREE TOOL</p>
    <h1>SwitchHunt</h1>
    <p class="sub">
      <strong>What’s the silent install switch?</strong> Drop a Windows installer below — we read it <strong>in your browser</strong>, the file never
      leaves your machine — identify the engine, and hand you the full command set: install, repair,
      uninstall, extract, plus the modifier flags. Works on ~85% of installers — MSI, WiX Burn, Advanced
      Installer, Inno, NSIS, InstallShield, InstallAware, BitRock, MSIX/AppX, Squirrel, Wise and
      self-extractors — and a curated catalog for the painful vendor one-offs (Citrix, Teams, AnyDesk…).
      The packed/custom long tail gets a best-effort switch harvest.
    </p>

    <!-- Dropzone -->
    <label id="drop" class="drop" for="file" tabindex="0">
      <input id="file" type="file" hidden accept=".exe,.msi,.msp,application/x-msdownload,application/x-msi" />
      <div class="drop-inner">
        <div class="drop-icon">⬇</div>
        <div class="drop-title">Drop an installer here, or click to choose</div>
        <div class="drop-hint">.exe or .msi · read locally, never uploaded</div>
      </div>
    </label>

    <p id="status" class="status" hidden></p>

    <!-- Result -->
    <section id="result" class="result" hidden>
      <header class="result-head">
        <div>
          <div class="result-engine" id="r-engine">—</div>
          <div class="result-file" id="r-file"></div>
        </div>
        <span class="badge" id="r-confidence">—</span>
      </header>

      <!-- Known silent string from the curated catalog (hard-coded, NOT read from the file) -->
      <div id="r-catalog" class="catalog" hidden></div>

      <!-- CMD ⇄ PowerShell: rewrites the command blocks for the chosen shell -->
      <div class="shell-toggle" id="r-shell" role="group" aria-label="Shell" hidden>
        <button type="button" class="shell-btn is-active" data-shell="cmd">CMD</button>
        <button type="button" class="shell-btn" data-shell="pwsh">PowerShell</button>
      </div>

      <div id="r-commands"></div>

      <p class="shell-hint" id="r-shell-hint" hidden>
        PowerShell: current-folder executables get <code>.\</code> and quoted paths get the
        <code>&amp;</code> call operator (applied above). If an argument itself contains quotes
        (e.g. InstallShield <code>/v"/qn"</code>) or a path with spaces, add <code>--%</code> right
        after the program name so PowerShell passes the rest verbatim.
      </p>

      <!-- Command builder (skeleton; options + props are populated/seeded per engine in the script) -->
      <div id="r-builder" class="builder" hidden>
        <div class="lbl">Build a command</div>
        <div class="builder-grid">
          <div class="b-row" data-ctl="op"><span class="b-label">Operation</span><div class="seg" id="b-op"></div></div>
          <div class="b-row" data-ctl="ui"><span class="b-label">UI level</span><div class="seg" id="b-ui"></div></div>
          <div class="b-row" data-ctl="dir"><span class="b-label" id="b-dir-label">Install dir</span><input class="b-input" id="b-dir" type="text" autocomplete="off" spellcheck="false" /></div>
          <div class="b-row" data-ctl="norestart"><span class="b-label"></span><label class="b-check"><input type="checkbox" id="b-norestart" checked /> No restart</label></div>
          <div class="b-row" data-ctl="log"><span class="b-label"></span><label class="b-check"><input type="checkbox" id="b-log" /> Log to file</label><input class="b-input b-input-sm" id="b-logpath" type="text" autocomplete="off" spellcheck="false" /></div>
          <div class="b-row" data-ctl="noupdates" hidden><span class="b-label"></span><label class="b-check"><input type="checkbox" id="b-noupdates" /> Skip update check <code>/exenoupdates</code></label></div>
          <div class="b-row" data-ctl="noprereqs" hidden><span class="b-label"></span><label class="b-check"><input type="checkbox" id="b-noprereqs" /> Skip prerequisites <code>/noprereqs</code></label></div>
          <div class="b-row" data-ctl="props" id="b-props-wrap" hidden><span class="b-label">Properties</span><div class="b-props" id="b-props"></div></div>
        </div>
        <div class="lbl">Result</div>
        <div class="cmd"><code id="b-out"></code><button type="button" class="copy" id="b-copy">Copy</button></div>
      </div>

      <!-- Deployment artifacts (generated client-side). .intunewin is the hero path (self-contained,
           framework-free); the PSADT v4 wrapper is the secondary "if you already live in PSADT" option. -->
      <div id="r-deploy" hidden>
        <p class="deploy-warn">⚠ Test the install command in a throwaway VM before you package or deploy it. These switches are detected/curated best-effort — a wrong one silently ships a broken package to every machine.</p>
        <section class="deploy deploy-primary">
          <div class="deploy-head">
            <h3>📦 Build a .intunewin <span class="rec-badge">Recommended</span></h3>
            <p class="deploy-why">Your installer + the silent command in one Intune-ready package — <strong>nothing else to install</strong>. No PSADT, no framework, no PowerShell-version gotchas. Built in your browser; the file never leaves your machine.</p>
          </div>
          <div id="r-intune-body"></div>
        </section>
        <details class="deploy deploy-secondary">
          <summary>📦 PSADT v4 wrapper (.ps1) — only if your shop standardizes on PSADT</summary>
          <div id="r-psadt-body"></div>
        </details>
      </div>

      <div id="r-modifiers-block" hidden>
        <div class="lbl">Modifiers</div>
        <p class="modifiers" id="r-modifiers"></p>
      </div>

      <!-- Custom property names harvested from the binary (Advanced Installer); built dynamically -->
      <div id="r-custom" hidden></div>

      <p class="notes" id="r-notes"></p>

      <!-- Opt-in best-effort switch harvest for custom/low-confidence installers -->
      <div id="r-besttry" hidden>
        <button type="button" class="besttry-btn" id="r-besttry-btn">⚡ Try to extract switches anyway</button>
        <div id="r-besttry-out"></div>
      </div>

      <!-- Deep MSI analysis (property matrix + uninstall-replay); built dynamically -->
      <div id="r-msi" hidden></div>

      <dl class="meta" id="r-meta" hidden></dl>
    </section>

    <!-- What it detects -->
    <section class="engines">
      <h2>What it detects</h2>
      <p class="engines-sub">
        Built for the enterprise long tail — Advanced Installer, Citrix and the vendor one-offs whose silent
        switches you’d otherwise reverse-engineer in Orca or dig out of a forum thread. Drop any of them and
        you get the exact command (install, repair, uninstall, plus modifier flags). Deterministic engines
        are rock-solid; the rest come with caveats.
      </p>
      <table class="engines-table">
        <thead><tr><th>Engine</th><th>Silent install</th><th>Confidence</th></tr></thead>
        <tbody>
          <tr><td>Windows Installer (MSI)</td><td><code>msiexec /i app.msi /qn /norestart</code></td><td><span class="ec ec-high">High</span></td></tr>
          <tr><td>WiX Burn bundle</td><td><code>setup.exe /install /quiet /norestart</code></td><td><span class="ec ec-high">High</span></td></tr>
          <tr><td>Advanced Installer</td><td><code>setup.exe /exenoui /qn</code></td><td><span class="ec ec-high">High</span></td></tr>
          <tr><td>Inno Setup</td><td><code>setup.exe /VERYSILENT /SUPPRESSMSGBOXES</code></td><td><span class="ec ec-high">High</span></td></tr>
          <tr><td>MSIX / AppX</td><td><code>Add-AppxPackage -Path app.msix</code></td><td><span class="ec ec-high">High</span></td></tr>
          <tr><td>NSIS</td><td><code>setup.exe /S</code></td><td><span class="ec ec-med">Medium</span></td></tr>
          <tr><td>InstallShield</td><td><code>setup.exe /s /v"/qn"</code></td><td><span class="ec ec-med">Medium</span></td></tr>
          <tr><td>InstallAware</td><td><code>setup.exe /s</code></td><td><span class="ec ec-med">Medium</span></td></tr>
          <tr><td>BitRock InstallBuilder</td><td><code>setup.exe --mode unattended</code></td><td><span class="ec ec-med">Medium</span></td></tr>
          <tr><td>Squirrel</td><td><code>Setup.exe --silent</code></td><td><span class="ec ec-med">Medium</span></td></tr>
          <tr><td>7-Zip / WinRAR SFX</td><td>unwrap → inner installer</td><td><span class="ec ec-med">Medium</span></td></tr>
          <tr><td>Wise (legacy)</td><td><code>setup.exe /s</code> (case-finicky)</td><td><span class="ec ec-low">Low</span></td></tr>
          <tr><td>📚 Vendor one-offs (Citrix, Teams, AnyDesk…)</td><td>known silent string from the catalog</td><td><span class="ec ec-high">Curated</span></td></tr>
          <tr><td>Custom / packed EXE</td><td>best-effort switch harvest</td><td><span class="ec ec-low">—</span></td></tr>
        </tbody>
      </table>
      <p class="engines-foot">
        MSI packages also get a deep read — the full property table, a tiered “properties you likely need”
        list, and an uninstall-replay warning. When an installer seals its switches inside a compressed payload
        (Citrix, custom .NET, big vendor bundles), a curated catalog of hand-verified silent strings fills the
        gap — and the truly custom EXEs we just can't crack, we say so rather than guess. <strong>That's where
        you come in:</strong> I built this because I was sick of reverse-engineering installers in Orca, and
        I've thrown every weird, vendor-cursed package I own at it — you've probably got one nastier. Drop the
        installer that beats it (or the magic switches we miss) in an
        <a href="https://github.com/deadarcher/SwitchHunt/issues/new?template=silent-install-string.yml" target="_blank" rel="noopener">issue on the repo</a>
        — the catalog only gets better with help, and I'm always happy to be proven wrong.
      </p>
    </section>

    <!-- Trust + scope -->
    <section class="info">
      <div class="info-col">
        <h2>Runs entirely in your browser</h2>
        <p>
          The installer is parsed locally with JavaScript — no upload, no server, no storage, nothing
          to leak. You can pull your network cable and it still works. Open DevTools and watch: zero
          requests leave the page.
        </p>
      </div>
      <div class="info-col">
        <h2>What it can and can’t do</h2>
        <p>
          It identifies the installer <em>engine</em> by signature and returns that engine’s documented
          command set — install, repair, uninstall, layout. It never runs the installer. Deterministic
          engines (MSI, WiX Burn, Advanced Installer, Inno, MSIX) are rock-solid; NSIS/InstallShield/
          Squirrel/SFX come with caveats; truly custom EXEs it can’t crack — that’s what the community
          catalog is for: a public, hand-verified set of known silent strings (and, for well-known apps,
          their real uninstall + detection), going live at
          <a href="https://github.com/deadarcher/SwitchHunt" target="_blank" rel="noopener">github.com/deadarcher/SwitchHunt</a>.
        </p>
      </div>
    </section>

    <p class="byline">
      Built by <a href="/">RFF</a> — the deploy tool for admins who got tired of reverse-engineering
      installers in Orca. Pushing this to a fleet is the boring part <a href="/">RFF automates</a>.
    </p>
  </main>
</Layout>

<style>
  .tool-nav {
    display: flex; justify-content: space-between; align-items: center;
    max-width: 760px; margin: 0 auto; padding: 22px 24px 0;
  }
  .tool-nav-by { font-size: 13px; color: var(--ink-3); transition: color 0.15s; }
  .tool-nav-by:hover { color: var(--brand); }

  .wrap { max-width: 760px; margin: 0 auto; padding: 40px 24px 88px; }
  .kicker {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px; letter-spacing: 0.12em; color: var(--brand); margin: 0 0 14px;
  }
  h1 {
    font-size: 40px; font-weight: 800; letter-spacing: -0.025em; line-height: 1.08;
    color: var(--ink); margin: 0 0 16px; text-wrap: balance;
  }
  .sub { font-size: 17px; line-height: 1.6; color: var(--ink-2); margin: 0 0 32px; text-wrap: pretty; }
  .sub strong { color: var(--ink); font-weight: 600; }

  .drop {
    display: block; border: 2px dashed var(--border-strong); border-radius: 14px;
    background: var(--surface); padding: 40px 24px; text-align: center; cursor: pointer;
    transition: border-color 0.15s, background 0.15s; outline: none;
  }
  .drop:hover, .drop:focus-visible, .drop.is-over {
    border-color: var(--brand); background: var(--brand-bg);
  }
  .drop-icon { font-size: 28px; color: var(--brand); margin-bottom: 8px; }
  .drop-title { font-size: 16px; font-weight: 600; color: var(--ink); }
  .drop-hint {
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 12px;
    color: var(--ink-3); margin-top: 6px;
  }

  .status { margin: 16px 0 0; font-size: 14px; color: var(--ink-2); }
  .status.err { color: var(--danger); }

  .result {
    margin-top: 28px; border: 1px solid var(--border); border-radius: 14px;
    background: var(--surface); padding: 24px;
  }
  .result-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
  .result-engine { font-size: 20px; font-weight: 700; color: var(--ink); }
  .result-file {
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 12px;
    color: var(--ink-3); margin-top: 4px; word-break: break-all;
  }
  .badge {
    flex-shrink: 0; font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10px;
    font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 4px 9px; border-radius: 999px; border: 1px solid;
  }
  .badge.high   { color: var(--success); background: var(--success-bg); border-color: var(--success); }
  .badge.medium { color: var(--warning); background: var(--warning-bg); border-color: var(--warning); }
  .badge.low, .badge.none {
    color: var(--ink-3); background: var(--surface-alt); border-color: var(--border-strong);
  }

  .modifiers {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12.5px; line-height: 1.7; color: var(--ink-2); margin: 0; text-wrap: pretty;
  }

  /* #r-msi is a static element (scoped). Its inner nodes are built dynamically in the page
     script, so their class rules live in the global block below (scoped rules can't reach them). */
  #r-msi { margin-top: 8px; }
  .meta {
    display: grid; grid-template-columns: auto 1fr; gap: 4px 16px; margin: 18px 0 0;
    padding-top: 16px; border-top: 1px solid var(--border); font-size: 13px;
  }
  .engines { margin: 48px 0 0; }
  .engines h2 { font-size: 22px; font-weight: 800; letter-spacing: -0.02em; color: var(--ink); margin: 0 0 8px; }
  .engines-sub { font-size: 15px; line-height: 1.6; color: var(--ink-2); margin: 0 0 20px; text-wrap: pretty; }
  .engines-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .engines-table th {
    text-align: left; font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px;
    letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-2); font-weight: 700;
    padding: 0 12px 8px 0; border-bottom: 1px solid var(--border);
  }
  .engines-table td { padding: 10px 12px 10px 0; border-bottom: 1px solid var(--border); color: var(--ink-2); vertical-align: top; }
  .engines-table td:first-child { color: var(--ink); font-weight: 600; }
  .engines-table code {
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 12.5px; color: var(--ink); word-break: break-all;
  }
  .ec {
    display: inline-block; font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10px;
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 2px 7px;
    border-radius: 999px; border: 1px solid; white-space: nowrap;
  }
  .ec-high { color: var(--success); background: var(--success-bg); border-color: var(--success); }
  .ec-med  { color: var(--warning); background: var(--warning-bg); border-color: var(--warning); }
  .ec-low  { color: var(--ink-3); background: var(--surface-alt); border-color: var(--border-strong); }
  .engines-foot { font-size: 13.5px; line-height: 1.6; color: var(--ink-3); margin: 18px 0 0; text-wrap: pretty; }
  .engines-foot a { color: var(--brand); text-decoration: underline; text-underline-offset: 2px; }

  .info { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin: 48px 0 0; }
  .info-col h2 { font-size: 17px; font-weight: 700; color: var(--ink); margin: 0 0 8px; }
  .info-col p { font-size: 14px; line-height: 1.65; color: var(--ink-2); margin: 0; text-wrap: pretty; }
  .info-col a { color: var(--brand); text-decoration: underline; text-underline-offset: 2px; }

  .byline {
    margin: 40px 0 0; padding-top: 24px; border-top: 1px solid var(--border);
    font-size: 14px; color: var(--ink-3); line-height: 1.6;
  }
  .byline a { color: var(--brand); text-decoration: underline; text-underline-offset: 2px; }

  @media (max-width: 720px) {
    .wrap { padding: 40px 20px 64px; }
    h1 { font-size: 30px; }
    .info { grid-template-columns: 1fr; gap: 24px; }
  }
</style>

<!--
  These rules target nodes built in the page script with document.createElement(). Such nodes don't
  carry Astro's scope attribute, so scoped class selectors (above) never match them. Declaring them
  global, prefixed with #result, applies them while keeping the styles confined to this page.
-->
<style is:global>
  #result .catalog {
    margin: 16px 0 4px; padding: 16px 18px; border: 1px solid var(--brand);
    border-left-width: 4px; border-radius: 10px; background: var(--brand-bg);
  }
  #result .catalog-head { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  #result .catalog-badge {
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase; color: #fff; background: var(--brand);
    padding: 3px 8px; border-radius: 999px;
  }
  #result .catalog-name { font-size: 16px; font-weight: 700; color: var(--ink); }
  #result .catalog-sub { font-size: 12.5px; line-height: 1.5; color: var(--ink-2); margin: 6px 0 0; }

  #result .shell-toggle {
    display: inline-flex; margin: 4px 0 18px; border: 1px solid var(--border-strong);
    border-radius: 8px; overflow: hidden;
  }
  #result .shell-btn {
    background: var(--surface-alt); border: none; color: var(--ink-3);
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; font-weight: 600;
    letter-spacing: 0.04em; padding: 6px 14px; cursor: pointer; transition: background 0.12s, color 0.12s;
  }
  #result .shell-btn + .shell-btn { border-left: 1px solid var(--border-strong); }
  #result .shell-btn:hover { color: var(--ink); }
  #result .shell-btn.is-active { background: var(--brand); color: #fff; }
  #result .shell-hint {
    font-size: 12.5px; line-height: 1.55; color: var(--ink-3); margin: 12px 0 0; text-wrap: pretty;
  }
  #result .shell-hint code {
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11.5px;
    background: var(--surface-alt); border-radius: 4px; padding: 1px 4px; color: var(--ink-2);
  }
  #result .besttry-btn {
    margin: 18px 0 0; background: var(--surface-alt); border: 1px dashed var(--border-strong);
    border-radius: 8px; color: var(--ink-2); font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px; font-weight: 600; padding: 8px 14px; cursor: pointer;
    transition: color 0.12s, border-color 0.12s;
  }
  #result .besttry-btn:hover { color: var(--brand); border-color: var(--brand); }
  #result .besttry-btn:disabled { opacity: 0.6; cursor: default; }

  #result .deploy {
    margin: 16px 0 0; border: 1px solid var(--border); border-radius: 10px;
    background: var(--surface-alt); padding: 2px 16px;
  }
  #result .deploy summary {
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 12px; font-weight: 700;
    letter-spacing: 0.04em; color: var(--ink); cursor: pointer; padding: 12px 0;
  }
  #result #r-intune-body, #result #r-psadt-body { padding-bottom: 14px; }
  #result .iw-row { display: flex; align-items: center; flex-wrap: wrap; gap: 4px; }
  #result .iw-status { font-size: 12.5px; color: var(--ink-3); }
  #result .test-note { margin: 12px 0 0; }
  #result .test-note > summary { font-size: 13px; font-weight: 600; color: var(--brand); cursor: pointer; }
  #result .test-note > summary:hover { text-decoration: underline; }
  #result .test-note .notes { margin-top: 6px; }
  #result .test-note .notes a { color: var(--brand); text-decoration: underline; text-underline-offset: 2px; }
  #result .deploy-warn {
    margin: 6px 0 14px; padding: 8px 12px; border-radius: 8px;
    background: var(--warning-bg); border: 1px solid var(--warning);
    color: var(--ink-2); font-size: 12.5px; line-height: 1.5; text-wrap: pretty;
  }
  /* .intunewin hero panel — the spotlighted, recommended path */
  #result .deploy-primary {
    margin: 16px 0 0; border: 1.5px solid var(--brand); border-radius: 12px;
    background: var(--brand-bg); padding: 18px 18px 8px;
  }
  #result .deploy-head h3 {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    margin: 0; font-size: 17px; font-weight: 800; letter-spacing: -0.01em; color: var(--ink);
  }
  #result .rec-badge {
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase; color: #fff; background: var(--brand);
    border-radius: 999px; padding: 3px 9px;
  }
  #result .deploy-why { margin: 8px 0 0; font-size: 13.5px; line-height: 1.6; color: var(--ink-2); text-wrap: pretty; }
  #result .deploy-secondary summary { color: var(--ink-2); font-weight: 600; }
  /* primary call-to-action (the in-browser .intunewin build button) */
  #result .primary-btn {
    margin: 16px 0 0; background: var(--brand); border: 1px solid var(--brand); color: #fff;
    border-radius: 8px; font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px; font-weight: 700; padding: 11px 18px; cursor: pointer;
    transition: filter 0.12s, box-shadow 0.12s; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
  }
  #result .primary-btn:hover { filter: brightness(1.07); box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12); }
  #result .primary-btn:disabled { opacity: 0.6; cursor: default; }

  #result .chips { display: flex; flex-wrap: wrap; gap: 6px; margin: 10px 0 0; }
  #result .chip {
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 12px; color: var(--ink);
