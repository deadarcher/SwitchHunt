  #result .seg-btn + .seg-btn { border-left: 1px solid var(--border-strong); }
  #result .seg-btn:hover { color: var(--ink); }
  #result .seg-btn.is-active { background: var(--brand); color: #fff; }
  #result .b-check { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: var(--ink-2); cursor: pointer; }
